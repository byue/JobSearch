AIRFLOW__CORE__DAGS_FOLDER=/home/byue/JobSearch/airflow/dags
PYTHONPATH=/home/byue/JobSearch

JOBSEARCH_AIRFLOW_COMPANIES=amazon,apple,google,meta,microsoft,netflix
# 0 means no cap (fetch all pages discoverable from total_results/page_size).
JOBSEARCH_AIRFLOW_MAX_PAGES=1
JOBSEARCH_AIRFLOW_META_TIMEOUT_SECONDS=20

JOBSEARCH_AIRFLOW_PROXY_RETRY_ATTEMPTS=6
JOBSEARCH_AIRFLOW_PROXY_RETRY_BACKOFF_SECONDS=2.0

JOBSEARCH_AIRFLOW_FAIL_ON_COMPANY_ERROR=false
JOBSEARCH_AIRFLOW_PROXY_MIN_READY=3
JOBSEARCH_AIRFLOW_PROXY_WARMUP_TIMEOUT_SECONDS=30.0

JOBSEARCH_PROXY_REDIS_URL=redis://localhost:6379/0
JOBSEARCH_PROXY_QUEUE_KEY=jobsearch:proxy:queue
JOBSEARCH_PROXY_SET_KEY=jobsearch:proxy:set
JOBSEARCH_PROXY_DENY_KEY=jobsearch:proxy:deny
JOBSEARCH_PROXY_QUEUE_ACQUIRE_TIMEOUT_SECONDS=6
JOBSEARCH_PROXY_DENY_COOLDOWN_SECONDS=900
