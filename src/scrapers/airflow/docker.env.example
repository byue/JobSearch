AIRFLOW_UID=50000

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Job
AIRFLOW_ADMIN_LASTNAME=Search
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW__CORE__MAX_MAP_LENGTH=100000
AIRFLOW__CORE__PARALLELISM=32
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16
AIRFLOW__CORE__XCOM_BACKEND=scrapers.airflow.xcom.minio_backend.MinioXComBackend
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jobsearch-xcom
MINIO_SECURE=false

JOBSEARCH_DB_URL=postgresql+psycopg2://airflow:airflow@postgres/airflow
JOBSEARCH_FEATURES_API_URL=http://features:8010
JOBSEARCH_ES_URL=http://elasticsearch:9200
JOBSEARCH_ES_ALIAS=jobs_catalog
JOBSEARCH_ES_INDEX_PREFIX=jobs_catalog__
JOBSEARCH_ES_EMBEDDING_DIMS=384
JOBSEARCH_ES_BULK_BATCH_SIZE=100

JOBSEARCH_AIRFLOW_COMPANIES=amazon,apple,google,meta,microsoft,netflix
JOBSEARCH_AIRFLOW_SCHEDULE_HOURS=4
# 0 means no cap (fetch all pages discoverable from total_results/page_size).
JOBSEARCH_AIRFLOW_MAX_PAGES=1
JOBSEARCH_AIRFLOW_TASK_RETRIES=2
JOBSEARCH_AIRFLOW_TASK_RETRY_DELAY_SECONDS=120
JOBSEARCH_AIRFLOW_CLIENT_REQUEST_TIMEOUT_SECONDS=15
JOBSEARCH_AIRFLOW_CLIENT_CONNECT_TIMEOUT_SECONDS=3
JOBSEARCH_AIRFLOW_CLIENT_MAX_RETRIES=3
JOBSEARCH_AIRFLOW_CLIENT_BACKOFF_FACTOR=0.5
JOBSEARCH_AIRFLOW_CLIENT_MAX_BACKOFF_SECONDS=6.0
JOBSEARCH_AIRFLOW_CLIENT_BACKOFF_JITTER=true
JOBSEARCH_AIRFLOW_PROXY_SENSOR_POKE_SECONDS=20
JOBSEARCH_AIRFLOW_PROXY_SENSOR_TIMEOUT_SECONDS=1800
JOBSEARCH_AIRFLOW_PROXY_MIN_AVAILABLE_PER_SCOPE=3
JOBSEARCH_AIRFLOW_PROXY_SENSOR_SOFT_FAIL=false

JOBSEARCH_PROXY_REDIS_URL=redis://redis:6379/0
JOBSEARCH_PROXY_API_URL=http://proxy-api:8090
JOBSEARCH_PROXY_API_TIMEOUT_SECONDS=10
JOBSEARCH_PROXY_LEASE_ACQUIRE_TIMEOUT_SECONDS=6.0
JOBSEARCH_PROXY_LEASE_POLL_INTERVAL_SECONDS=0.1
JOBSEARCH_PROXY_BLOCKED_COOLDOWN_SECONDS=900
JOBSEARCH_PROXY_LEASE_TTL_SECONDS=300
JOBSEARCH_PROXY_LEASE_MAX_ATTEMPTS=50
JOBSEARCH_PROXY_QUEUE_MAX_SIZE=128
JOBSEARCH_PROXY_VALIDATE_TIMEOUT_SECONDS=2.5
JOBSEARCH_PROXY_LIST_FETCH_TIMEOUT_SECONDS=15.0
JOBSEARCH_PROXY_VALIDATE_WORKERS=32
JOBSEARCH_PROXY_SCOPES=www.amazon.jobs,jobs.apple.com,www.google.com,www.metacareers.com,apply.careers.microsoft.com,explore.jobs.netflix.net
JOBSEARCH_PROXY_PRODUCER_SLEEP_SECONDS=0.5
JOBSEARCH_PROXY_PRODUCER_HEARTBEAT_SECONDS=15.0
JOBSEARCH_PROXY_PRODUCER_LOG_LEVEL=INFO
